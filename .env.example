# Ruta base del sitio (GitHub Pages con repo nombrado: /PortafolioWeb | Vercel/Netlify: /)
BASE_PATH=/PortafolioWeb

# URL pública del sitio (sin barra final). Usada en SEO y vista previa al compartir (WhatsApp, etc.)
PUBLIC_SITE_URL=https://tu-usuario.github.io/PortafolioWeb

# Usuario de GitHub para repos y estadísticas
PUBLIC_GITHUB_USERNAME=CesarEduL

# Nombre del PDF del CV en public/ (opcional; por defecto: cv.pdf)
# PUBLIC_CV_FILENAME=cv.pdf

# Token de GitHub (solo build-time, NO uses prefijo PUBLIC_ ni GITHUB_*)
GH_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Formulario de contacto (Web3Forms - gratuito)
# https://web3forms.com/
PUBLIC_WEB3FORMS_ACCESS_KEY=tu-access-key-aqui

# Opcional: correo donde recibirás los mensajes del formulario
PUBLIC_CONTACT_EMAIL=correo@ejemplo.com

# Analytics (opcional — elige uno)
# Plausible: https://plausible.io/
# PUBLIC_PLAUSIBLE_DOMAIN=tu-dominio.com
# Umami: https://umami.is/
# PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
