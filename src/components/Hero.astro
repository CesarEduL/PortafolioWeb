---
import { siteConfig } from "../config/site";
---

<section
  class="relative min-h-[70vh] flex flex-col md:flex-row items-center justify-center gap-xl md:gap-24 pt-12 md:pt-20 fade-in-up visible"
  id="inicio"
>
  <div class="flex-1 text-center md:text-left space-y-lg relative z-10 order-2 md:order-1">
    {
      siteConfig.available && (
        <div class="inline-flex items-center gap-2 px-md py-xs rounded-full glass-panel neon-border mb-md">
          <span class="w-2 h-2 rounded-full bg-success-neon animate-pulse" />
          <span class="font-label-caps text-label-caps text-success-neon tracking-widest">
            Disponible para trabajar
          </span>
        </div>
      )
    }

    <h1 class="font-display-lg-mobile text-display-lg-mobile md:font-display-lg md:text-display-lg text-text-primary leading-tight">
      Hola 👋, soy <br />
      <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-primary-container to-secondary block mt-2 text-5xl md:text-7xl font-extrabold"
      >
        {siteConfig.name}
      </span>
    </h1>

    <p class="font-label-caps text-label-caps md:text-lg tracking-[0.2em] text-primary/80 max-w-2xl mx-auto md:mx-0">
      {siteConfig.role}
    </p>

    <div class="flex flex-wrap items-center justify-center md:justify-start gap-md pt-lg">
      <a class="btn-primary flex items-center gap-2 group" href="#proyectos">
        Ver Proyectos
        <span class="material-symbols-outlined text-[20px] group-hover:translate-x-1 transition-transform"
          >arrow_forward</span
        >
      </a>
      <a class="btn-secondary flex items-center gap-2 px-lg" href={siteConfig.cvUrl}>
        <span class="material-symbols-outlined text-[20px]">download</span>
        Descargar CV
      </a>
      <a
        class="p-sm glass-panel rounded-lg hover:bg-surface-variant transition-colors text-on-surface-variant hover:text-primary motion-safe:hover:scale-110 motion-safe:hover:-translate-y-1 ml-sm"
        href={siteConfig.githubUrl}
        rel="noopener noreferrer"
        target="_blank"
      >
        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="relative order-1 md:order-2 profile-img-container">
    <div class="relative w-56 h-56 md:w-80 md:h-80">
      <div class="absolute inset-[-10px] rounded-full bg-primary/20 blur-2xl animate-pulse"></div>
      <div
        class="w-full h-full rounded-full p-1.5 bg-gradient-to-tr from-primary via-secondary to-transparent animate-[spin_8s_linear_infinite] shadow-[0_0_40px_rgba(125,207,255,0.2)]"
      >
        <div class="w-full h-full rounded-full overflow-hidden border-4 border-background bg-surface-container relative">
          <img
            alt={`${siteConfig.name} Profile Photo`}
            class="w-full h-full object-cover animate-[spin_-8s_linear_infinite]"
            src={siteConfig.profileImage}
          />
        </div>
      </div>
      <div
        class="absolute -right-2 top-2 glass-panel p-2.5 rounded-2xl flex items-center justify-center neon-border shadow-lg animate-bounce motion-safe:hover:scale-110 transition-transform"
      >
        <span class="material-symbols-outlined text-primary text-2xl">code</span>
      </div>
      <div
        class="absolute -left-2 bottom-12 glass-panel p-2.5 rounded-2xl flex items-center justify-center neon-border shadow-lg animate-bounce motion-safe:hover:scale-110 transition-transform"
        style="animation-delay: 1.5s;"
      >
        <span class="material-symbols-outlined text-secondary text-2xl">android</span>
      </div>
    </div>
  </div>
</section>
