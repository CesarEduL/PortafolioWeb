---
import { siteConfig } from "../config/site";

const hasForm = Boolean(siteConfig.web3formsAccessKey);
---

<section class="scroll-mt-24 fade-in-up pb-12 w-full" id="contacto">
  <div class="mb-xl md:mb-[64px]">
    <h1 class="font-display-lg text-display-lg text-primary mb-sm" data-i18n="sections.contact">Contacto</h1>
    <p class="font-body-base text-body-base text-text-secondary max-w-2xl" data-i18n="sections.contactSub">
      ¿Interesado en colaborar en un proyecto o discutir oportunidades tecnológicas? Completa el formulario y abriré un
      canal de comunicación.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl md:gap-[32px] items-start">
    <div class="col-span-1 lg:col-span-5 flex flex-col gap-lg">
      <div class="relative w-full aspect-video rounded-xl overflow-hidden border border-outline-glass bg-surface-container-high group">
        <img
          alt="Cyberpunk workspace setup"
          class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-700 mix-blend-luminosity"
          src={siteConfig.contactImage}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-surface-dark/90 to-transparent flex items-end p-md">
          <div class="font-code-sm text-code-sm text-primary flex items-center gap-sm">
            <span class="w-2 h-2 rounded-full bg-success-neon animate-pulse"></span>
            <span data-i18n="contact.online">Sistema en línea</span>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-md mt-sm">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest" data-i18n="contact.networks">
          Redes Profesionales
        </h3>
        <a
          class="flex items-center gap-md p-md rounded-lg bg-surface-container-low border border-outline-glass hover:border-primary/50 hover:bg-surface-container transition-all duration-300 group"
          href={siteConfig.linkedinUrl}
          rel="noopener noreferrer"
          target="_blank"
        >
          <div
            class="w-10 h-10 rounded bg-surface-slate flex items-center justify-center text-primary group-hover:shadow-[0_0_10px_rgba(195,230,255,0.3)] transition-shadow"
          >
            <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </div>
          <div class="flex-grow">
            <div class="font-body-bold text-body-bold text-on-surface">LinkedIn</div>
            <div class="font-code-sm text-code-sm text-text-secondary">/in/cesar-camero</div>
          </div>
          <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors"
            >arrow_forward</span
          >
        </a>
        <a
          class="flex items-center gap-md p-md rounded-lg bg-surface-container-low border border-outline-glass hover:border-secondary/50 hover:bg-surface-container transition-all duration-300 group"
          href={siteConfig.githubUrl}
          rel="noopener noreferrer"
          target="_blank"
        >
          <div
            class="w-10 h-10 rounded bg-surface-slate flex items-center justify-center text-secondary group-hover:shadow-[0_0_10px_rgba(212,187,255,0.3)] transition-shadow"
          >
            <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                clip-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                fill-rule="evenodd"></path>
            </svg>
          </div>
          <div class="flex-grow">
            <div class="font-body-bold text-body-bold text-on-surface">GitHub</div>
            <div class="font-code-sm text-code-sm text-text-secondary">@{siteConfig.githubUsername}</div>
          </div>
          <span class="material-symbols-outlined text-outline-variant group-hover:text-secondary transition-colors"
            >arrow_forward</span
          >
        </a>
      </div>
    </div>

    <div class="col-span-1 lg:col-span-7">
      <div class="bg-surface-slate/65 backdrop-blur-xl border border-outline-glass rounded-xl p-md md:p-[40px] shadow-2xl relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/20 rounded-full blur-[60px] pointer-events-none"></div>

        {
          !hasForm && (
            <div class="relative z-10 mb-lg rounded-lg border border-warning-neon/40 bg-warning-neon/10 p-md text-sm text-on-surface" data-i18n="contact.formMissing">
              Configura PUBLIC_WEB3FORMS_ACCESS_KEY en tu archivo .env para activar el formulario de contacto.
            </div>
          )
        }

        <form
          action="https://api.web3forms.com/submit"
          class="flex flex-col gap-lg relative z-10"
          id="contactForm"
          method="POST"
        >
          {hasForm && <input name="access_key" type="hidden" value={siteConfig.web3formsAccessKey} />}
          {siteConfig.contactEmail && (
            <input name="redirect" type="hidden" value={`mailto:${siteConfig.contactEmail}`} />
          )}
          <input name="subject" type="hidden" value="Nuevo mensaje desde el portafolio" />
          <input name="from_name" type="hidden" value="Portafolio Web" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
            <div class="flex flex-col gap-sm">
              <label class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-2" for="name">
                <span class="material-symbols-outlined text-[16px]">person</span>
                <span data-i18n="contact.name">Nombre</span>
              </label>
              <input
                class="bg-surface-container-high border border-outline-variant rounded-md px-4 py-3 text-on-surface font-body-base text-body-base placeholder:text-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all bg-transparent"
                data-i18n-placeholder="contact.placeholder.name"
                id="name"
                name="name"
                placeholder="Tu nombre completo"
                required
                type="text"
              />
            </div>
            <div class="flex flex-col gap-sm">
              <label class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-2" for="email">
                <span class="material-symbols-outlined text-[16px]">mail</span>
                <span data-i18n="contact.email">Correo Electrónico</span>
              </label>
              <input
                class="bg-surface-container-high border border-outline-variant rounded-md px-4 py-3 text-on-surface font-body-base text-body-base placeholder:text-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all bg-transparent"
                data-i18n-placeholder="contact.placeholder.email"
                id="email"
                name="email"
                placeholder="correo@ejemplo.com"
                required
                type="email"
              />
            </div>
          </div>

          <div class="flex flex-col gap-sm">
            <label class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-2" for="subject-field">
              <span class="material-symbols-outlined text-[16px]">subject</span>
              <span data-i18n="contact.subject">Asunto</span>
            </label>
            <input
              class="bg-surface-container-high border border-outline-variant rounded-md px-4 py-3 text-on-surface font-body-base text-body-base placeholder:text-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all bg-transparent"
              data-i18n-placeholder="contact.placeholder.subject"
              id="subject-field"
              name="custom_subject"
              placeholder="¿De qué trata tu mensaje?"
              required
              type="text"
            />
          </div>

          <div class="flex flex-col gap-sm">
            <label class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-2" for="message">
              <span class="material-symbols-outlined text-[16px]">chat_bubble</span>
              <span data-i18n="contact.message">Mensaje</span>
            </label>
            <textarea
              class="bg-surface-container-high border border-outline-variant rounded-md px-4 py-3 text-on-surface font-body-base text-body-base placeholder:text-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all resize-y min-h-[120px] bg-transparent"
              data-i18n-placeholder="contact.placeholder.message"
              id="message"
              name="message"
              placeholder="Describe los detalles aquí..."
              required
              rows="5"></textarea>
          </div>

          <div class="mt-md flex flex-col sm:flex-row sm:items-center sm:justify-between gap-md">
            <p class="text-sm text-on-surface-variant hidden" id="formStatus"></p>
            <button
              class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-primary to-secondary text-on-primary-fixed font-body-bold text-body-bold px-8 py-3 rounded-lg hover:shadow-[0_0_15px_rgba(195,230,255,0.5)] active:scale-95 transition-all duration-300 w-full sm:w-auto sm:ml-auto disabled:opacity-50"
              disabled={!hasForm}
              type="submit"
            >
              <span data-i18n="contact.submit">Enviar Transmisión</span>
              <span class="material-symbols-outlined text-[20px]">send</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { ui } from "../i18n/ui";

  function getLang() {
    return localStorage.getItem("portfolio-lang") === "en" ? "en" : "es";
  }

  function getFormMessages() {
    const lang = getLang();
    return {
      sending: ui[lang]["contact.sending"],
      success: ui[lang]["contact.success"],
      error: ui[lang]["contact.error"],
    };
  }

  function bindContactForm() {
    const form = document.getElementById("contactForm") as HTMLFormElement | null;
    const status = document.getElementById("formStatus");
    if (!form || form.dataset.bound === "true") return;
    form.dataset.bound = "true";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!status) return;

      const msgs = getFormMessages();
      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      submitButton?.setAttribute("disabled", "true");
      status.classList.remove("hidden", "text-error", "text-success-neon");
      status.textContent = msgs.sending;

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
        });
        const data = await response.json();

        if (data.success) {
          status.textContent = msgs.success;
          status.classList.add("text-success-neon");
          form.reset();
        } else {
          throw new Error(data.message ?? "Error");
        }
      } catch {
        status.textContent = msgs.error;
        status.classList.add("text-error");
      } finally {
        submitButton?.removeAttribute("disabled");
      }
    });
  }

  bindContactForm();
  document.addEventListener("astro:page-load", bindContactForm);
</script>
