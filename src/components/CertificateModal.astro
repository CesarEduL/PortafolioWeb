<dialog
  class="cert-modal fixed inset-0 z-[100] m-0 h-full max-h-none w-full max-w-none border-0 bg-transparent p-0 backdrop:bg-black/70 backdrop:backdrop-blur-sm open:flex open:items-center open:justify-center"
  id="certModal"
>
  <div
    class="cert-modal-panel relative mx-gutter flex w-full max-w-3xl flex-col overflow-hidden bg-surface shadow-2xl"
  >
    <div class="flex items-center justify-between gap-md px-md py-sm shrink-0">
      <h3 class="font-body-bold text-primary truncate text-sm md:text-base" id="certModalTitle">
        Certificado
      </h3>
      <div class="flex items-center gap-xs shrink-0">
        <a
          class="hidden sm:inline-flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary transition-colors"
          href="#"
          id="certModalExternal"
          rel="noopener noreferrer"
          target="_blank"
        >
          <span class="material-symbols-outlined text-[16px]">open_in_new</span>
          <span data-i18n="experience.openExternal">Abrir en pestaña</span>
        </a>
        <button
          aria-label="Cerrar"
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-on-surface-variant hover:text-primary hover:bg-primary/10 transition-colors"
          data-i18n-aria="experience.close"
          id="certModalClose"
          type="button"
        >
          <span class="material-symbols-outlined text-[22px]">close</span>
        </button>
      </div>
    </div>
    <div class="relative w-full h-[85vh] min-h-[560px]">
      <iframe
        class="absolute inset-0 h-full w-full border-0 bg-transparent"
        id="certModalFrame"
        loading="lazy"
        referrerpolicy="no-referrer"
        title="Certificado"
      ></iframe>
    </div>
  </div>
</dialog>

<script>
  function bindCertificateModal() {
    const dialog = document.getElementById("certModal") as HTMLDialogElement | null;
    const frame = document.getElementById("certModalFrame") as HTMLIFrameElement | null;
    const titleEl = document.getElementById("certModalTitle");
    const external = document.getElementById("certModalExternal") as HTMLAnchorElement | null;
    const closeBtn = document.getElementById("certModalClose");

    if (!dialog || !frame || dialog.dataset.bound === "true") return;
    dialog.dataset.bound = "true";

    function closeModal() {
      if (dialog.open) dialog.close();
      frame.src = "";
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-cert-preview]").forEach((btn) => {
      if (btn instanceof HTMLButtonElement && btn.dataset.certBound === "true") return;
      if (btn instanceof HTMLButtonElement) btn.dataset.certBound = "true";

      btn.addEventListener("click", () => {
        const preview = btn.getAttribute("data-cert-preview");
        const view = btn.getAttribute("data-cert-view");
        const title = btn.getAttribute("data-cert-title");
        if (!preview) return;

        if (titleEl && title) titleEl.textContent = title;
        if (external && view) external.href = view;

        frame.src = preview;
        document.body.style.overflow = "hidden";
        if (!dialog.open) dialog.showModal();
      });
    });

    closeBtn?.addEventListener("click", closeModal);

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) closeModal();
    });

    dialog.addEventListener("close", () => {
      frame.src = "";
      document.body.style.overflow = "";
    });

    dialog.addEventListener("cancel", () => {
      frame.src = "";
      document.body.style.overflow = "";
    });
  }

  bindCertificateModal();
  document.addEventListener("astro:page-load", bindCertificateModal);
</script>

<style>
  .cert-modal::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }

  html.light .cert-modal-panel {
    @apply bg-white;
  }
</style>
