---
import { siteConfig } from "../config/site";

interface Props {
  trophySrc: string;
  trophyFallbacks?: string[];
}

const { trophySrc, trophyFallbacks = [] } = Astro.props;
const fallbacksJson = JSON.stringify(trophyFallbacks);
---

<section class="scroll-mt-24 fade-in-up" id="logros">
  <h2 class="font-headline-md text-headline-md text-primary mb-sm flex items-center gap-md">
    <span class="material-symbols-outlined">emoji_events</span>
    <span data-i18n="sections.achievements">Logros de GitHub</span>
    <div class="h-px bg-gradient-to-r from-outline-glass to-transparent flex-grow ml-md"></div>
  </h2>
  <p class="text-on-surface-variant text-sm mb-xl max-w-3xl" data-i18n="sections.achievementsSub">
    Trofeos generados desde tu actividad pública en GitHub.
  </p>

  <div class="glass-panel p-md rounded-2xl neon-border hover-lift flex justify-center overflow-x-auto">
    <img
      id="github-trophy-img"
      alt="GitHub Profile Trophy"
      class="w-full max-w-5xl h-auto rounded-lg min-h-[8rem]"
      data-fallbacks={fallbacksJson}
      decoding="async"
      loading="lazy"
      referrerpolicy="no-referrer"
      src={trophySrc}
    />
  </div>
  <p class="text-on-surface-variant text-xs mt-sm text-center">
    <a
      class="hover:text-primary transition-colors"
      href={`https://github.com/${siteConfig.githubUsername}`}
      rel="noopener noreferrer"
      target="_blank"
    >
      Ver perfil en GitHub
    </a>
  </p>
</section>

<script>
  function bindTrophyFallback() {
    const img = document.getElementById("github-trophy-img");
    if (!(img instanceof HTMLImageElement)) return;
    if (img.dataset.fallbackBound === "true") return;
    img.dataset.fallbackBound = "true";

    let fallbacks: string[] = [];
    try {
      fallbacks = JSON.parse(img.dataset.fallbacks ?? "[]");
    } catch {
      fallbacks = [];
    }

    let fallbackIndex = 0;
    img.addEventListener("error", () => {
      if (fallbackIndex >= fallbacks.length) return;
      const next = fallbacks[fallbackIndex];
      fallbackIndex += 1;
      if (next && img.src !== next) img.src = next;
    });
  }

  bindTrophyFallback();
  document.addEventListener("astro:page-load", bindTrophyFallback);
</script>
