---
import { getGitHubStatsUrl, getGitHubStreakUrl, siteConfig } from "../config/site";

const statsUrl = getGitHubStatsUrl(siteConfig.githubUsername);
const streakUrl = getGitHubStreakUrl(siteConfig.githubUsername);
---

<section class="scroll-mt-24 fade-in-up" id="estadisticas">
  <h2 class="font-headline-md text-headline-md text-primary mb-xl flex items-center gap-md">
    <span class="material-symbols-outlined">bar_chart</span>
    Estadísticas
    <div class="h-px bg-gradient-to-r from-outline-glass to-transparent flex-grow ml-md"></div>
  </h2>

  <div class="flex flex-col lg:flex-row gap-lg justify-center items-center">
    <div class="glass-panel p-md rounded-2xl neon-border hover-lift w-full lg:w-1/2 flex justify-center">
      <img
        alt="GitHub Stats"
        class="w-full h-auto max-w-md rounded-lg"
        loading="lazy"
        referrerpolicy="no-referrer"
        src={statsUrl}
      />
    </div>
    <div class="glass-panel p-md rounded-2xl neon-border hover-lift w-full lg:w-1/2 flex justify-center">
      <img
        alt="GitHub Streak"
        class="w-full h-auto max-w-md rounded-lg"
        loading="lazy"
        referrerpolicy="no-referrer"
        src={streakUrl}
      />
    </div>
  </div>
</section>
