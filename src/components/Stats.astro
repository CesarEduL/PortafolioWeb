---
import {
  getGitHubStatsFallbackUrl,
  getGitHubStatsUrl,
  getGitHubStreakUrl,
  getGitHubTopLangsUrl,
  siteConfig,
} from "../config/site";

const username = siteConfig.githubUsername;
const statsUrl = getGitHubStatsUrl(username);
const statsFallbackUrl = getGitHubStatsFallbackUrl(username);
const streakUrl = getGitHubStreakUrl(username);
const topLangsUrl = getGitHubTopLangsUrl(username);
---

<section class="scroll-mt-24 fade-in-up" id="estadisticas">
  <h2 class="font-headline-md text-headline-md text-primary mb-xl flex items-center gap-md">
    <span class="material-symbols-outlined">bar_chart</span>
    Estadísticas
    <div class="h-px bg-gradient-to-r from-outline-glass to-transparent flex-grow ml-md"></div>
  </h2>

  <div class="flex flex-col gap-lg">
    <div class="flex flex-col lg:flex-row gap-lg justify-center items-center">
      <div class="glass-panel p-md rounded-2xl neon-border hover-lift w-full lg:w-1/2 flex justify-center min-h-[10rem]">
        <img
          id="github-stats-img"
          alt="GitHub Stats"
          class="w-full h-auto max-w-md rounded-lg"
          data-fallback={statsFallbackUrl}
          loading="lazy"
          referrerpolicy="no-referrer"
          src={statsUrl}
        />
      </div>
      <div class="glass-panel p-md rounded-2xl neon-border hover-lift w-full lg:w-1/2 flex justify-center">
        <img
          alt="GitHub Streak"
          class="w-full h-auto max-w-md rounded-lg"
          loading="lazy"
          referrerpolicy="no-referrer"
          src={streakUrl}
        />
      </div>
    </div>

    <div class="glass-panel p-md rounded-2xl neon-border hover-lift flex justify-center mx-auto w-full max-w-2xl">
      <img
        alt="Lenguajes más usados en GitHub"
        class="w-full h-auto rounded-lg"
        loading="lazy"
        referrerpolicy="no-referrer"
        src={topLangsUrl}
      />
    </div>
  </div>
</section>

<script>
  const statsImg = document.getElementById("github-stats-img") as HTMLImageElement | null;
  if (statsImg) {
    statsImg.addEventListener("error", () => {
      const fallback = statsImg.dataset.fallback;
      if (fallback && statsImg.src !== fallback) {
        statsImg.src = fallback;
      }
    });
  }
</script>
