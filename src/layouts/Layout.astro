---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Analytics from "../components/Analytics.astro";
import SitePreferences from "../components/SitePreferences.astro";
import { getSiteOrigin, siteConfig } from "../config/site";

interface Props {
  title?: string;
  description?: string;
}

const { title = siteConfig.title, description = siteConfig.description } = Astro.props;

const siteOrigin = getSiteOrigin();
const canonicalPath = Astro.url.pathname.replace(/\/index\.html$/, "/");
const canonicalUrl = new URL(canonicalPath, `${siteOrigin}/`).href;
const ogImage = siteConfig.ogImageUrl;
---

<!doctype html>
<html class="scroll-smooth" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:alt" content={`${siteConfig.name} — ${siteConfig.role}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${siteConfig.name} — ${siteConfig.role}`} />
    <link rel="icon" href={siteConfig.faviconUrl} type="image/png" />
    <link rel="apple-touch-icon" href={siteConfig.faviconUrl} />
    <title>{title}</title>
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <script is:inline>
      (function () {
        function resolveTheme() {
          const stored = localStorage.getItem("portfolio-theme");
          if (stored === "light" || stored === "dark") return stored;
          return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        }

        function applyThemeToDocument(doc) {
          const root = doc.documentElement;
          const theme = resolveTheme();
          const isLight = theme === "light";
          root.classList.toggle("light", isLight);
          root.classList.toggle("dark", !isLight);
          root.style.colorScheme = isLight ? "light" : "dark";
        }

        function applyLangToDocument(doc) {
          const lang = localStorage.getItem("portfolio-lang");
          if (lang === "en" || lang === "es") doc.documentElement.lang = lang;
        }

        applyThemeToDocument(document);
        applyLangToDocument(document);

        document.addEventListener("astro:before-swap", (event) => {
          applyThemeToDocument(event.newDocument);
          applyLangToDocument(event.newDocument);
        });
      })();
    </script>
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <Analytics />
    <ViewTransitions />
  </head>
  <body
    class="bg-background text-on-surface font-body-base antialiased min-h-screen flex flex-col relative overflow-x-hidden selection:bg-primary/30 selection:text-primary"
  >
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-[-1]">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-primary/10 blur-[120px] animate-blob"></div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-secondary/10 blur-[120px] animate-blob animation-delay-2000"
      >
      </div>
      <div
        class="absolute top-[40%] left-[60%] w-[30%] h-[30%] rounded-full bg-tertiary/10 blur-[120px] animate-blob animation-delay-4000"
      >
      </div>
    </div>

    <slot />

    <SitePreferences />

    <script>
      function initFadeInUp() {
        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { root: null, rootMargin: "0px", threshold: 0.08 },
        );

        document.querySelectorAll(".fade-in-up:not(.visible)").forEach((element) => {
          const rect = element.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.92) {
            element.classList.add("visible");
          } else {
            observer.observe(element);
          }
        });
      }

      function scrollToTargetFromUrl() {
        let hash = window.location.hash;
        if (!hash) {
          const pending = sessionStorage.getItem("portfolio-scroll-hash");
          if (pending) {
            hash = pending;
            sessionStorage.removeItem("portfolio-scroll-hash");
            history.replaceState(
              null,
              "",
              `${window.location.pathname}${window.location.search}${pending}`,
            );
          }
        }

        if (!hash) {
          window.scrollTo({ top: 0, left: 0, behavior: "instant" });
          return;
        }

        const id = decodeURIComponent(hash.replace(/^#/, ""));
        const scrollToSection = () => {
          const el = document.getElementById(id);
          if (!el) return false;
          el.scrollIntoView({ behavior: "smooth", block: "start" });
          return true;
        };

        requestAnimationFrame(() => {
          if (!scrollToSection()) {
            window.setTimeout(scrollToSection, 80);
          }
        });
      }

      function initScrollNav() {
        const sections = document.querySelectorAll("section[id]");
        const navLinks = document.querySelectorAll(".nav-desktop-link");

        let current = "";
        sections.forEach((section) => {
          const sectionTop = (section as HTMLElement).offsetTop;
          const sectionHeight = section.clientHeight;
          if (window.pageYOffset >= sectionTop - sectionHeight / 3) {
            current = section.getAttribute("id") ?? "";
          }
        });

        navLinks.forEach((link) => {
          link.classList.remove("text-primary", "nav-active");
          link.classList.add("text-on-surface-variant");
          if (link.getAttribute("href")?.includes(current) && current !== "") {
            link.classList.remove("text-on-surface-variant");
            link.classList.add("text-primary", "nav-active");
          }
        });

        const nav = document.getElementById("mainNav");
        if (nav) {
          nav.classList.toggle("shadow-md", window.scrollY > 50);
        }
      }

      document.addEventListener("DOMContentLoaded", () => {
        initFadeInUp();
        initScrollNav();
        document.getElementById("inicio")?.classList.add("visible");
      });

      document.addEventListener("astro:page-load", () => {
        initFadeInUp();
        initScrollNav();
        scrollToTargetFromUrl();
      });

      window.addEventListener("hashchange", scrollToTargetFromUrl);
      window.addEventListener("scroll", initScrollNav);
    </script>
  </body>
</html>

<style is:global>
  .nav-active::after {
    content: "";
    position: absolute;
    bottom: -0.25rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0.25rem;
    height: 0.25rem;
    background-color: #c3e6ff;
    border-radius: 9999px;
  }

  html.light .nav-active::after {
    background-color: #00658c;
  }
</style>
