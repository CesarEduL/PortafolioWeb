---
import PageLayout from "../../layouts/PageLayout.astro";
import FeaturedProjects from "../../components/FeaturedProjects.astro";
import MoreRepos from "../../components/MoreRepos.astro";
import { siteConfig } from "../../config/site";
import { fetchGitHubRepos } from "../../lib/github";
import { featuredProjects } from "../../data/featured-projects";
import { enrichFeaturedProjects, excludeFeaturedRepos } from "../../lib/projects";
import { routes } from "../../lib/navigation";

const repos = await fetchGitHubRepos(siteConfig.githubUsername);
const featured = enrichFeaturedProjects(featuredProjects, repos, siteConfig.githubUsername);
const moreRepos = excludeFeaturedRepos(repos, featuredProjects);
---

<PageLayout title={`Proyectos — ${siteConfig.name}`}>
  <a class="text-primary text-sm hover:underline inline-flex items-center gap-1 -mb-md" href={routes.home}>
    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
    <span data-i18n="nav.home">Inicio</span>
  </a>
  <FeaturedProjects projects={featured} />
  <MoreRepos repos={moreRepos} />
</PageLayout>
